{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Photography Content Manifest",
  "type": "object",
  "properties": {
    "mediaType": {
      "type": "string",
      "title": "Media Type",
      "default": "image/jpeg",
      "readOnly": true
    },
    "fileSize": {
      "type": "integer",
      "title": "File Size (bytes)",
      "readOnly": true
    },
    "creator": {
      "type": "string",
      "title": "Photographer Name"
    },
    "exifData": {
      "type": "object",
      "title": "Exif Metadata",
      "properties": {
        "cameraMake": {
          "type": "string",
          "title": "Camera Make"
        },
        "cameraModel": {
          "type": "string",
          "title": "Camera Model"
        },
        "exposure": {
          "type": "string",
          "title": "Exposure Settings"
        },
        "focalLength": {
          "type": "string",
          "title": "Focal Length"
        }
      },
      "required": ["cameraMake", "cameraModel"]
    },
    "creativeWork": {
      "type": "object",
      "title": "Creative Work Assertion",
      "properties": {
        "@context": {
          "type": "string",
          "default": "https://schema.org",
          "readOnly": true
        },
        "@type": {
          "type": "string",
          "default": "CreativeWork",
          "readOnly": true
        },
        "creator": {
          "type": "string",
          "title": "Photographer Name"
        },
        "dateCreated": {
          "type": "string",
          "format": "date-time",
          "title": "Creation Date"
        },
        "location": {
          "type": "string",
          "title": "Location"
        },
        "description": {
          "type": "string",
          "title": "Description"
        }
      },
      "required": ["creator", "dateCreated"]
    },
    "metadata": {
      "type": "object",
      "title": "Metadata & Licensing",
      "properties": {
        "tags": {
          "type": "array",
          "title": "Tags/Keywords",
          "items": { "type": "string" }
        },
        "license": {
          "type": "string",
          "enum": ["Copyright", "CC BY", "CC BY-NC", "Public Domain"],
          "title": "License Type"
        },
        "externalLicenseUrl": {
          "type": "string",
          "format": "uri",
          "title": "License URL"
        },
        "usageRestrictions": {
          "type": "string",
          "title": "Usage Restrictions"
        },
        "attribution": {
          "type": "string",
          "title": "Additional Attribution"
        }
      },
      "required": ["license"]
    },
    "aiPermissions": {
      "type": "object",
      "title": "AI/ML Permissions",
      "properties": {
        "dataMining": {
          "type": "string",
          "enum": ["allowed", "notAllowed", "constrained"],
          "default": "notAllowed",
          "title": "Data Mining"
        },
        "aiInference": {
          "type": "string",
          "enum": ["allowed", "notAllowed", "constrained"],
          "default": "notAllowed",
          "title": "AI Inference"
        },
        "aiTraining": {
          "type": "string",
          "enum": ["allowed", "notAllowed", "constrained"],
          "default": "notAllowed",
          "title": "AI Training (Generative)"
        },
        "aiTrainingNonGenerative": {
          "type": "string",
          "enum": ["allowed", "notAllowed", "constrained"],
          "default": "notAllowed",
          "title": "AI Training (Non-generative)"
        },
        "constraintsInfo": {
          "type": "string",
          "title": "Additional Constraints",
          "description": "Provide additional constraints if any permission is set to constrained"
        }
      },
      "required": ["dataMining", "aiInference", "aiTraining", "aiTrainingNonGenerative"]
    },
    "contentVersion": {
      "type": "string",
      "title": "Content Version",
      "default": "v1.0"
    },
    "externalReferences": {
      "type": "array",
      "title": "External References",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "title": "Description"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "title": "URL"
          }
        },
        "required": ["url"]
      }
    }
  },
  "required": ["mediaType", "fileSize", "creator", "exifData", "creativeWork", "metadata", "aiPermissions", "contentVersion"]
} 