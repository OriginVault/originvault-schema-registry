{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Animation/Video Content Manifest",
  "type": "object",
  "properties": {
    "mediaType": {
      "type": "string",
      "title": "Media Type",
      "default": "video/mp4",
      "readOnly": true
    },
    "fileSize": {
      "type": "integer",
      "title": "File Size (bytes)",
      "readOnly": true
    },
    "creator": {
      "type": "string",
      "title": "Creator Name"
    },
    "videoMetadata": {
      "type": "object",
      "title": "Video Metadata",
      "properties": {
        "duration": {
          "type": "string",
          "title": "Duration (e.g., 00:02:30)"
        },
        "frameRate": {
          "type": "number",
          "title": "Frame Rate (fps)"
        },
        "resolution": {
          "type": "string",
          "title": "Resolution (e.g., 1920x1080)"
        }
      },
      "required": ["duration", "frameRate"]
    },
    "creativeWork": {
      "type": "object",
      "title": "Creative Work Assertion",
      "properties": {
        "@context": {
          "type": "string",
          "default": "https://schema.org",
          "readOnly": true
        },
        "@type": {
          "type": "string",
          "default": "VideoObject",
          "readOnly": true
        },
        "creator": {
          "type": "string",
          "title": "Creator Name"
        },
        "dateCreated": {
          "type": "string",
          "format": "date-time",
          "title": "Creation Date"
        },
        "description": {
          "type": "string",
          "title": "Description"
        },
        "keywords": {
          "type": "array",
          "title": "Keywords",
          "items": { "type": "string" }
        }
      },
      "required": ["creator", "dateCreated"]
    },
    "metadata": {
      "type": "object",
      "title": "Metadata & Licensing",
      "properties": {
        "license": {
          "type": "string",
          "enum": ["Copyright", "CC BY", "CC BY-NC", "Public Domain"],
          "title": "License Type"
        },
        "externalLicenseUrl": {
          "type": "string",
          "format": "uri",
          "title": "License URL"
        },
        "usageRestrictions": {
          "type": "string",
          "title": "Usage Restrictions"
        }
      },
      "required": ["license"]
    },
    "aiPermissions": {
      "type": "object",
      "title": "AI/ML Permissions",
      "properties": {
        "dataMining": {
          "type": "string",
          "enum": ["allowed", "notAllowed", "constrained"],
          "default": "notAllowed",
          "title": "Data Mining"
        },
        "aiInference": {
          "type": "string",
          "enum": ["allowed", "notAllowed", "constrained"],
          "default": "notAllowed",
          "title": "AI Inference"
        },
        "aiTraining": {
          "type": "string",
          "enum": ["allowed", "notAllowed", "constrained"],
          "default": "notAllowed",
          "title": "AI Training (Generative)"
        },
        "aiTrainingNonGenerative": {
          "type": "string",
          "enum": ["allowed", "notAllowed", "constrained"],
          "default": "notAllowed",
          "title": "AI Training (Non-generative)"
        },
        "constraintsInfo": {
          "type": "string",
          "title": "Additional Constraints",
          "description": "Provide details if any permission is set to constrained"
        }
      },
      "required": ["dataMining", "aiInference", "aiTraining", "aiTrainingNonGenerative"]
    },
    "contentVersion": {
      "type": "string",
      "title": "Content Version",
      "default": "v1.0"
    },
    "externalReferences": {
      "type": "array",
      "title": "External References",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "title": "Description"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "title": "URL"
          }
        },
        "required": ["url"]
      }
    }
  },
  "required": [
    "mediaType",
    "fileSize",
    "creator",
    "videoMetadata",
    "creativeWork",
    "metadata",
    "aiPermissions",
    "contentVersion"
  ]
} 